def search(name ,name1, name2):
    res = list()
    name11 = once(name1)
    name22 = once(name2)
    A = AdjacencyMatrix(name1, name2)
    n = name11.index(name)
    l = len(name22)
    for i in range(l):
        if A[n][i] == 1:
            x = name22[i]
            res.append(x)
    return res

def plot_graph(list1, list2):
        list11 = once(list1)
        list22 = once(list2)
        adj_matrix = AdjacencyMatrix(list1, list2)
        G = nx.DiGraph()
        G.add_nodes_from(list1, bipartite=0)  
        G.add_nodes_from(list2, bipartite=1)  
        for i in range(len(list11)):
            for j in range(len(list22)):
                if adj_matrix[i][j] == 1:
                    G.add_edge(list22[j], list11[i])
        pos = nx.bipartite_layout(G, list1)
        name_list1 = [k for k,v in locals().items() if v == list1[0]]
        name_list2 = [k for k,v in locals().items() if v == list2[0]]
        plt.figure(figsize=(16, 10))
        nx.draw_networkx(G, pos, with_labels=True, node_size=1000, node_color='lightblue', edge_color='darkblue', font_size=12)
        plt.title("Knowledge Graph")
        plt.axis('off')
        plt.show()
