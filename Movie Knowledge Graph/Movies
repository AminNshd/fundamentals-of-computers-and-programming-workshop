import json
import networkx as nx
import matplotlib.pyplot as plt

def listof(list1, list2):
    d = dict()
    for i in range(len(list1)):
        d[list1[i]] = []
    for i in range(len(list1)):
        if list2[i] not in d[list1[i]]:
            d[list1[i]].append(list2[i])
    return d

def once(list):
    lst = []
    for i in list:
        if i not in lst:
            lst.append(i)
    return lst

def AdjacencyMatrix(list1, list2):
    list11 = once(list1)
    list22 = once(list2)
    A = listof(list1, list2)
    res = []
    lst = []
    for i in list11:
        res.append(lst)
        lst = []
        for j in list22:
            if j in A[i]:
                lst.append(int(1))
            else:
                lst.append(int(0))
    res.pop(0)
    lst = []
    for j in list22:
        if j in A[list11[-1]]:
            lst.append(int(1))
        else:
            lst.append(int(0))
    res.append(lst)
    return res
